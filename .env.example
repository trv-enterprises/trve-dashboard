# Dashboard Production Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED
# =============================================================================

# Anthropic API key for AI features (chart builder, etc.)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Domain for HTTPS certificates (Caddy/Let's Encrypt)
# Use your actual domain for production, or 'localhost' for local dev
DOMAIN=dashboard.example.com

# =============================================================================
# OPTIONAL (have sensible defaults)
# =============================================================================

# Server configuration
# DASHBOARD_SERVER_PORT=3001
# DASHBOARD_SERVER_MODE=release

# MongoDB connection
# DASHBOARD_MONGODB_URI=mongodb://mongodb:27017
# DASHBOARD_MONGODB_DATABASE=dashboard

# Redis connection
# DASHBOARD_REDIS_ADDR=redis:6379
# DASHBOARD_REDIS_PASSWORD=

# =============================================================================
# NOTES
# =============================================================================
#
# For Caddy to obtain Let's Encrypt certificates automatically:
# - Your domain must be publicly accessible on ports 80 and 443
# - DNS must point to your server's IP address
# - For private/local deployments, use DOMAIN=localhost (self-signed cert)
#
# To deploy:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose -f docker-compose.prod.yml up -d --build
