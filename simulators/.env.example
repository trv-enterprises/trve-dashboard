# WebSocket Simulator
WS_INTERVAL_MS=1000          # Broadcast interval in milliseconds
WS_NUM_SENSORS=5             # Number of simulated sensors
WS_ENABLE_NOISE=true         # Add random noise to readings
WS_ANOMALY_RATE=0.02         # Rate of anomalous readings (0-1)

# REST API Simulator
API_BUFFER_SIZE=1000         # Number of readings to keep in memory
API_GENERATE_MS=5000         # Generate new readings every N ms

# Database Seeder
NUM_SENSORS=10               # Number of sensors to create
DAYS_BACK=7                  # Days of historical data to generate
INTERVAL_SECONDS=60          # Seconds between readings

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sensors
